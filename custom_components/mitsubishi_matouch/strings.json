{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    },
    "flow_title": "Mitsubishi MA Touch {mac}",
    "step": {
      "user": {
        "title": "Configure New Thermostat",
        "data": {
          "mac": "MAC address",
          "pin": "PIN"
        }
      },
      "confirm_bluetooth": {
        "title": "Configure New Thermostat",
        "data": {
          "pin": "PIN"
        }
      }
    },
    "error": {
      "invalid_mac_address": "Invalid MAC address",
      "invalid_pin": "Invalid PIN"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Mitsubishi MA Touch options",
        "data": {
          "persistent_connection": "Persistent connection (Android-style)"
        },
        "data_description": {
          "persistent_connection": "Keep one long-lived BLE link to the panel and reuse it across polling cycles, like the official Android app. Reduces login/logout chatter and BLE setup overhead, at the cost of holding a connection slot continuously. Off by default (each poll is a full connect+login+logout+disconnect)."
        }
      }
    }
  },
  "entity": {
    "climate": {
      "matouch": {
        "state_attributes": {
          "fan_mode": {
            "state": {
              "quiet": "Quiet"
            }
          }
        }
      }
    }
  }
}
